# ==========================================
# BAGEL BOYZ NJ - Environment Configuration
# ==========================================

# Server
NODE_ENV=production
PORT=4000
TZ=America/New_York

# Database (Hostinger MySQL)
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=

# JWT / Security
JWT_SECRET=
ENCRYPTION_KEY=

# AI Services
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# Image / Video Generation
KIE_API_KEY=
HEYGEN_API_KEY=

# Social Media - Facebook/Instagram (Meta Graph API)
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
INSTAGRAM_APP_ID=

# Social Media - Platform tokens stored in DB (oauth_integrations table)
# Facebook Page Access Token -> encrypted in social_accounts table
# Instagram -> connected via Facebook page

# Google Business Profile
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_PLACES_API_KEY=

# Website
BACKEND_URL=http://localhost:4000
FRONTEND_URL=https://bagelboyznj.com

# Error Tracking (optional)
SENTRY_DSN=

# ─────────────────────────────────────────────────────────────
# Kitchen Print Bridge  (src/print-bridge.js)
# Only needed on the machine AT THE SHOP that talks to the printer.
# ─────────────────────────────────────────────────────────────
BB_SITE_URL=https://bagelboyznj.com

# Which store this bridge prints for: holmdel | airport
BB_PRINT_LOC=holmdel

# Must match printing.poll_key in includes/order-config.php
BB_PRINT_KEY=

# The Star TSP143IIIW's IP on the shop wifi. Hold FEED while powering the
# printer on and it prints a self-test page showing this. Give it a STATIC
# IP in the router or it will change and printing will stop.
BB_PRINTER_IP=192.168.1.50
BB_PRINTER_PORT=9100

# How often to check for new tickets, in milliseconds.
BB_PRINT_POLL_MS=4000
